# ─── Environment Management ──────────────────────────────────
# Three environments exist: Local, QA, Production.
# This file configures Local development.
# QA and Production use GitHub Environments with scoped secrets.
# See docs/08-ENVIRONMENTS.md for the full setup guide.
# ──────────────────────────────────────────────────────────────

# GitHub credentials for the add-event API.
# Grant the token write access to the repository contents.
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=SBsommar
GITHUB_REPO=sbsommar
GITHUB_BRANCH=main

# Restrict CORS to this origin. Leave empty to disable CORS header entirely.
ALLOWED_ORIGIN=http://localhost:3000

# Optional second allowed origin (e.g. QA/staging environment).
# QA_ORIGIN=

# Absolute URL of the add-event API endpoint, injected into the form at build time.
# Leave unset for local dev (defaults to relative /add-event).
# API_URL=

# Absolute base URL used for RSS feed links, per-event page URLs, and QR codes.
# Required for npm run build.
SITE_URL=http://localhost:3000

# Port for the Node.js server (Passenger sets this automatically on Inleed).
PORT=3000

# Shared parent domain for the session cookie (e.g. sbsommar.se).
# Injected into client-side JS at build time so cookie write-back
# uses the same Domain attribute as the server (02-§18.47).
# Leave unset for single-origin / local dev.
# COOKIE_DOMAIN=

# Environment name for QA camp isolation (02-§42.17).
# Set to 'qa' or 'production' in deployed environments.
# Leave unset for local dev (no camp filtering applied).
# BUILD_ENV=

# GoatCounter site code for analytics (02-§63.10).
# Set to the GoatCounter site code (e.g. 'sbsommar') in production.
# Leave unset for local dev (no analytics script rendered).
# GOATCOUNTER_SITE_CODE=

# HMAC signing secret that validates admin tokens (02-§91.1, §91.32).
# Tokens are signed (namn_roll_epoch_sig), not listed — mint them with
# `npm run admin:create`, which reads this secret. Use a long random value
# (>= 32 bytes). Generate with: openssl rand -base64 48
# Leave unset to disable admin features.
# ADMIN_TOKEN_SECRET=

# Secret key for signing activity-ownership session cookies (02-§18, #387).
# Edit/delete authorisation rests on an HMAC-SHA256 signature keyed by this
# value, so it MUST be a long, random, secret string — a weak value lets an
# attacker forge ownership and edit/delete other people's activities.
# Use at least 32 random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave unset locally to disable cookie-based ownership (fails closed).
# In QA/Production set it via GitHub Environments secrets (see docs/08-ENVIRONMENTS.md).
# SESSION_SECRET=

# Comma-separated list of trusted reverse-proxy IPs (PHP API only, #387/#371).
# X-Forwarded-For is only honoured for the rate-limit client IP when the direct
# peer (REMOTE_ADDR) is in this list; otherwise REMOTE_ADDR is used. Leave unset
# when the API is not behind a proxy (the common shared-hosting case).
# TRUSTED_PROXIES=
