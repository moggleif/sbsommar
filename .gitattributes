# Normalize all text files to LF
* text=auto eol=lf

# Binary / LFS assets — no line ending conversion
*.jpg filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text

# Test fixtures — tiny images stored directly in git (not LFS)
tests/fixtures/*.webp -filter -diff -merge binary
