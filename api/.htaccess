# Deny HTTP access to dotfiles (.env, .git, .htpasswd, …) before routing.
# The RewriteCond below skips existing files, so without this an existing
# .env would be served as plaintext (§100, 02-§100.4). The IfModule pair
# covers both Apache 2.4 (mod_authz_core) and 2.2 (Order/Deny).
<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [QSA,L]
