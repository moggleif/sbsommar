# Deny HTTP access to any .env file under the web root (§100, 02-§100.5).
# Defense in depth: the API .env lives outside the web root, but a stray
# .env anywhere under public_html must never be served. The IfModule pair
# covers both Apache 2.4 (mod_authz_core) and 2.2 (Order/Deny).
<Files ".env">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</Files>

# Cache headers for static assets (02-§67.1–67.3)
#
# Images: 1 year (immutable content, filename changes on update)
# CSS/JS: 1 week (may change between deploys)
# HTML:   no caching (always revalidate for fresh content)

<IfModule mod_headers.c>
  # Images — 1 year
  <FilesMatch "\.(webp|png|jpg|jpeg|ico)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>

  # CSS and JS — 1 week
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=604800, public"
  </FilesMatch>

  # Service worker — always revalidate (must come after the JS rule)
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # HTML — always revalidate
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>

  # ── Security headers (#384) ───────────────────────────────────────────────
  # Defence-in-depth on top of the output encoding and Markdown sanitiser.
  #
  # Content-Security-Policy: 'unsafe-inline' is required for script-src because
  # the build injects per-page inline <script> blocks carrying event JSON
  # (window.__EVENTS__) and there is no per-request nonce on static Apache
  # hosting. The policy still blocks cross-origin script injection, framing,
  # plugins, and <base> hijacking. GoatCounter loads count.js from gc.zgo.at
  # and beacons to *.goatcounter.com.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://gc.zgo.at; connect-src 'self' https://*.goatcounter.com; img-src 'self' data: https://*.goatcounter.com; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
